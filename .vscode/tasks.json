{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake-configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build"
            ],
            "problemMatcher": [],
            "detail": "Configure the CMake project into the build/ directory."
        },
        {
            "label": "cmake-build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--config",
                "Debug"
            ],
            "problemMatcher": [
                "$msCompile"
            ],
            "detail": "Build the project with cmake build tools."
        },
        {
            "label": "build-app",
            "type": "shell",
            "dependsOrder": "sequence",
            "dependsOn": [
                "cmake-configure",
                "cmake-build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "detail": "Configure with cmake then build with MSVC."
        }
    ]
}
