{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++20",
                "-iquote",
                "${workspaceFolder}\\src",
                "-iquote",
                "${workspaceFolder}\\src\\instructions",
                "${workspaceFolder}\\src\\*.cpp",
                "${workspaceFolder}\\src\\instructions\\*.cpp",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}\\src"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build the whole CSOPESY project (all .cpp files) and run from main.cpp."
        },
        {
            "type": "cppbuild",
            "label": "build-app",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++20",
                "-iquote",
                "${workspaceFolder}\\src",
                "-iquote",
                "${workspaceFolder}\\src\\instructions",
                "${workspaceFolder}\\src\\*.cpp",
                "${workspaceFolder}\\src\\instructions\\*.cpp",
                "-o",
                "${workspaceFolder}\\src\\main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}\\src"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Build all sources into src\\main.exe (used by the Run/Debug launch config)."
        }
    ],
    "version": "2.0.0"
}
